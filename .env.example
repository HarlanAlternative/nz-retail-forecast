# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Stats NZ Aotearoa Data Explorer API key
# Obtain from: https://api.stats.govt.nz/
ADE_API_KEY=your_subscription_key_here

# MLflow tracking (optional: set to a remote URI for team use)
MLFLOW_TRACKING_URI=mlruns/

# FastAPI settings
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
